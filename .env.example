# ─── Google Gemini (Primary AI) ─────────────────────────────
# Get one at: https://aistudio.google.com/apikey  (free tier: 1,500 req/day)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Model overrides (optional)
GEMINI_EXTRACT_MODEL=gemini-2.0-flash-001
GEMINI_CLASSIFIER_MODEL=gemini-2.0-flash-001
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role — SERVER-ONLY. Never expose to client.
# Used by extractor to read private documents from Storage.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Bucket name where invoice files are stored.
SUPABASE_DOC_BUCKET=documents

# ─── Extractor tuning ───────────────────────────────────────
# Reject if AI's own self-rated confidence below this threshold.
EXTRACT_MIN_CONFIDENCE=0.60

# Max PDF size to process (bytes). Default 20 MB.
EXTRACT_MAX_FILE_BYTES=20971520

# ─── App URL (for absolute fetches from server) ─────────────
NEXT_PUBLIC_APP_URL=https://www.logisticsnex.com
